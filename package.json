{
	"name": "next-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "PORTLESS_TLD=app portless",
		"dev:app": "next dev",
		"build": "next build",
		"start": "next start",
		"lint:check": "ultracite check",
		"lint": "ultracite fix",
		"typecheck": "tsc --noEmit",
		"deps:check": "taze",
		"deps:update": "taze --write --install",
		"deps:update:minor": "taze minor --write --install",
		"deps:update:major": "taze major --write --install",
		"commit": "cz",
		"commitlint": "commitlint --edit",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@phosphor-icons/react": "^2.1.10",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"next": "16.2.10",
		"next-themes": "^0.4.6",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"shadcn": "^4.13.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.2.0",
		"@tailwindcss/postcss": "^4.3.2",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"commitizen": "^4.3.2",
		"cz-conventional-changelog": "^3.3.0",
		"eslint-plugin-github": "^6.0.0",
		"eslint-plugin-sonarjs": "^4.1.0",
		"lefthook": "^2.1.9",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-plugin-react-doctor": "^0.7.1",
		"portless": "^0.15.1",
		"tailwindcss": "^4.3.2",
		"taze": "^19.14.1",
		"typescript": "^6.0.3",
		"ultracite": "^7.9.2"
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"portless": {
		"name": "new.cargill",
		"script": "dev:app"
	}
}
