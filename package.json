{
	"name": "next-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "PORTLESS_TLD=app portless",
		"dev:app": "next dev",
		"build": "next build",
		"start": "next start",
		"lint:check": "ultracite check",
		"lint": "ultracite fix",
		"typecheck": "tsc --noEmit",
		"commit": "cz",
		"commitlint": "commitlint --edit",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"next": "16.2.10",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.2.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"babel-plugin-react-compiler": "1.0.0",
		"commitizen": "^4.3.2",
		"cz-conventional-changelog": "^3.3.0",
		"eslint-plugin-github": "^6.0.0",
		"eslint-plugin-sonarjs": "^4.1.0",
		"lefthook": "^2.1.9",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-plugin-react-doctor": "^0.7.1",
		"portless": "^0.15.1",
		"tailwindcss": "^4",
		"typescript": "^5",
		"ultracite": "^7.9.2"
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"portless": {
		"name": "new.cargill",
		"script": "dev:app"
	}
}
