{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:best-practices",
		"group:allNonMajor",
		":enableVulnerabilityAlerts"
	],
	"prConcurrentLimit": 3,
	"vulnerabilityAlerts": {
		"minimumReleaseAge": null
	},
	"packageRules": [
		{
			"description": "TypeScript 7 is Go-native and drops the JS Compiler API that Next.js still requires for typechecking. Re-enable once Next.js stable supports it (experimental useTypeScriptCli on canary).",
			"matchPackageNames": ["typescript"],
			"allowedVersions": "<7"
		},
		{
			"groupName": "Next.js and React",
			"groupSlug": "nextjs-react",
			"matchPackageNames": [
				"next",
				"react",
				"react-dom",
				"@types/react",
				"@types/react-dom"
			]
		},
		{
			"groupName": "Tailwind CSS",
			"groupSlug": "tailwindcss",
			"matchPackageNames": [
				"tailwindcss",
				"@tailwindcss/postcss",
				"tw-animate-css"
			]
		},
		{
			"groupName": "code quality tooling",
			"groupSlug": "code-quality",
			"matchPackageNames": [
				"ultracite",
				"oxfmt",
				"oxlint",
				"typescript",
				"@types/node",
				"babel-plugin-react-compiler"
			]
		},
		{
			"groupName": "GitHub Actions",
			"groupSlug": "github-actions",
			"matchManagers": ["github-actions"]
		}
	]
}
